# x-studio-ai environment configuration
# Copy this file to .env.local and fill in your values.

# ── Direct LLM connection (client → LLM) ──────────────────────────────────────
# Used when VITE_STUDIO_SERVER_URL is not set.
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o
# Optional: static bearer token sent as X-Studio-Token header (e.g. for proxies)
# LLM_TOKEN=change-me

# ── Dev server connection (client → x-studio-dev-server) ─────────────────────
# When set, the app routes AI and data queries through the dev server instead of
# connecting directly to the LLM or using in-memory data.
# VITE_STUDIO_SERVER_URL=http://localhost:3020
# VITE_STUDIO_SERVER_TOKEN=   # JWT from GET /api/dev-token (leave blank for open dev mode)
