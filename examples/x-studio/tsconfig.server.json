{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "@mui/x-studio-middleware": ["../../packages/x-studio-middleware/src/index.ts"],
      "@mui/x-studio-middleware/*": ["../../packages/x-studio-middleware/src/*"]
    }
  },
  "include": ["src/server/**/*"]
}
