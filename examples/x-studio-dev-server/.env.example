# x-studio-dev-server environment configuration
# Copy this file to .env.local and fill in your values.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3020

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default — no extra setup required)
DB_CLIENT=better-sqlite3
DB_FILENAME=./sales.db

# PostgreSQL (comment out SQLite settings above and uncomment these)
# DB_CLIENT=pg
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=studio
# DB_USER=studio
# DB_PASSWORD=studio

# MySQL / MariaDB (comment out SQLite settings above and uncomment these)
# DB_CLIENT=mysql2
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=studio
# DB_USER=studio
# DB_PASSWORD=studio

# ── Seeding ────────────────────────────────────────────────────────────────────
# Number of orders to generate on first run (more = more data but slower seed)
SEED_ORDER_COUNT=500

# ── AI ─────────────────────────────────────────────────────────────────────────
LLM_API_KEY=sk-...
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o

# ── Security ───────────────────────────────────────────────────────────────────
# Secret used to sign dev JWTs. Change this to a random string in production.
JWT_SECRET=dev-secret-change-in-production

# Uncomment to require a static token on all API requests (dev guard).
# STUDIO_TOKEN=change-me-to-a-random-secret

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3004,http://localhost:3005,http://localhost:3006
