# AI Chat Assistant configuration
# Copy this file to .env.local and fill in your values.

# ─── Option A: Direct (dev only) ─────────────────────────────────────────────
# Sends requests directly from the browser to the LLM API.
# WARNING: The API key will be visible in your app bundle — never use in production.
#
# LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# ─── Option B: Server-side proxy (recommended) ───────────────────────────────
# The proxy holds the API key server-side. See examples/x-studio-ai-proxy for
# the sample proxy server (run it with `npm run dev` on port 3010).
#
LLM_ENDPOINT=http://localhost:3010/v1/chat/completions
# LLM_MODEL=gpt-4o
#
# Optional shared secret — must match STUDIO_TOKEN in the proxy .env.
# If set, the proxy will reject requests that omit this header.
# LLM_TOKEN=change-me-to-a-random-secret
