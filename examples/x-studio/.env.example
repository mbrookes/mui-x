# AI Chat Assistant configuration
# Copy this file to .env.local and fill in your values.
#
# WARNING: Browser-exposed API keys are a security risk.
# In production, route LLM requests through a server-side proxy.
# The VITE_AI_* variables are visible to anyone who inspects your app bundle.

# OpenAI-compatible endpoint (required to enable AI chat)
VITE_AI_ENDPOINT=https://api.openai.com/v1/chat/completions

# API key (optional if your endpoint doesn't require auth, e.g. a local Ollama server)
VITE_AI_API_KEY=sk-...

# Model name (optional, defaults to gpt-4o)
VITE_AI_MODEL=gpt-4o
