# Server configuration
PORT=3010

# OpenAI API key — stored here, never in the browser app
OPENAI_API_KEY=sk-...

# Upstream LLM endpoint (defaults to OpenAI; change for Azure, Ollama, etc.)
# OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions

# Optional: shared secret the client must send as X-Studio-Token header.
# Set this to require auth from the browser app. Leave unset to allow all requests.
# STUDIO_TOKEN=change-me-to-a-random-secret

# CORS: comma-separated list of allowed origins, or * to allow all.
# In production, restrict this to your app's domain.
# ALLOWED_ORIGINS=http://localhost:3004,http://localhost:3005
