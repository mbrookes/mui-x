{
  // Extend the repo base so the example resolves every `@mui/x-*` workspace
  // package; see examples/x-studio/tsconfig.json for the full rationale (the
  // standalone paths block was incomplete and the strict flags applied to the
  // unbuilt workspace source this config pulls in).
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
