# x-studio environment configuration
# Copy this file to .env.local and fill in your values.

# ── AI (direct LLM connection) ─────────────────────────────────────────────────
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o
# Optional: static bearer token sent as X-Studio-Token header
# LLM_TOKEN=change-me

# ── Dev server connection (optional) ──────────────────────────────────────────
# When set, routes AI queries through the local dev server instead of directly
# to the LLM.
# VITE_STUDIO_SERVER_URL=http://localhost:3020
# VITE_STUDIO_SERVER_TOKEN=
