# x-studio-ai environment configuration
# Copy this file to .env.local and fill in your values.

# ── Dev server connection (client → x-studio-dev-server) ─────────────────────
# AI and data queries are routed through x-studio-dev-server.
# Start the dev server: cd examples/x-studio-dev-server && pnpm dev
VITE_STUDIO_SERVER_URL=http://localhost:3020

# ── Security ───────────────────────────────────────────────────────────────────
# Secret used to sign dev JWTs. Change this to a random string in production.
JWT_SECRET=dev-secret-change-in-production

# Optional: JWT from GET /api/dev-token (leave blank for open dev mode)
# VITE_STUDIO_SERVER_TOKEN=
