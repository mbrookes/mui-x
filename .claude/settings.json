{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && \"$CLAUDE_PROJECT_DIR/node_modules/.bin/prettier\" --write --ignore-path \"$CLAUDE_PROJECT_DIR/.lintignore\" --ignore-unknown \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting with prettier..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/react-doctor-stop.sh\"",
            "asyncRewake": true,
            "statusMessage": "React Doctor: checking for regressions...",
            "rewakeSummary": "React Doctor found regressions",
            "rewakeMessage": "React Doctor regression check failed."
          }
        ]
      }
    ]
  }
}
