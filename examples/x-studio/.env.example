# x-studio environment configuration
# Copy this file to .env.local and fill in your values.

# ── Dev server connection ──────────────────────────────────────────────────────
# AI and data queries are routed through x-studio-dev-server.
# Start the dev server: cd examples/x-studio-dev-server && pnpm dev
VITE_STUDIO_SERVER_URL=http://localhost:3020
# Optional: token for authenticated server setups
# VITE_STUDIO_SERVER_TOKEN=
