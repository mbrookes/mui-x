    "composite": true,
    "declaration": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "build/esm",
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": ["../../mui-env.d.ts", "@mui/material/themeCssVarsAugmentation"]
